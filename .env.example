# ── Payhero API Credentials ──
PAYHERO_API_USERNAME=your_payhero_username
PAYHERO_API_PASSWORD=your_payhero_password
PAYHERO_CHANNEL_ID=your_channel_id

# ── Callback URL (must be publicly accessible for Payhero callbacks) ──
# On Render, this will be https://your-app-name.onrender.com/api/callback
PAYHERO_CALLBACK_URL=https://your-app-name.onrender.com/api/callback

# ── Server Port (Render sets this automatically) ──
# PORT=3000
