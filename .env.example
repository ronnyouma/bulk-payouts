# Daraja API Credentials
DARAJA_ENVIRONMENT=sandbox
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret

# Daraja B2C Credentials
DARAJA_SHORTCODE=your_b2c_enabled_paybill_or_shortcode
DARAJA_INITIATOR_NAME=your_initiator_name
DARAJA_SECURITY_CREDENTIAL=your_encrypted_security_credential
DARAJA_COMMAND_ID=BusinessPayment

# Callback URLs must be publicly accessible in production.
# On Render, use:
# https://your-app-name.onrender.com/api/b2c/result
# https://your-app-name.onrender.com/api/b2c/timeout
DARAJA_RESULT_URL=https://your-app-name.onrender.com/api/b2c/result
DARAJA_TIMEOUT_URL=https://your-app-name.onrender.com/api/b2c/timeout

# Render sets this automatically.
# PORT=3000
